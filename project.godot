; Godot 4.3 project file
; Snake Aether — premium native Android snake game

config_version=5

[application]

config/name="Snake Aether"
config/description="A premium neon snake game built on Godot 4. Multiple modes, real lighting, bloom, particles, procedural music."
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"
config/version="1.0.0"
boot_splash/show_image=true
boot_splash/fullsize=false
boot_splash/use_filter=true
boot_splash/bg_color=Color(0.02, 0.03, 0.05, 1)

[autoload]

SaveData="*res://SaveData.gd"
AudioManager="*res://AudioManager.gd"
GameSignals="*res://GameSignals.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/handheld/orientation=1
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/per_pixel_transparency/allowed=false
window/vsync/vsync_mode=1
mouse_cursor/sentinel_aabb_size=Vector2(10, 10)

