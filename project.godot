[layer_names]

2d_render/layer_1="World"
2d_render/layer_2="Snake"
2d_render/layer_3="Effects"
2d_render/layer_4="UI"

[rendering]

renderer/rendering_method="forward_plus"
renderer/rendering_method.mobile="mobile"
environment/defaults/default_clear_color=Color(0.02, 0.03, 0.05, 1)
anti_aliasing/quality/msaa_2d=2
2d/snap/snap_2d_transforms_to_pixel=true
textures/canvas_textures/default_texture_filter=1
